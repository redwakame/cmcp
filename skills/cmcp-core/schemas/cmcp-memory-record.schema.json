{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/cmcp-openclaw/schemas/cmcp-memory-record.schema.json",
  "title": "CmcpMemoryRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "memory_id",
    "layer",
    "memory_type",
    "source_kind",
    "source_ref",
    "user_ownership",
    "confidence",
    "status",
    "created_at",
    "updated_at",
    "sensitivity"
  ],
  "properties": {
    "memory_id": {
      "type": "string",
      "minLength": 1
    },
    "layer": {
      "type": "string",
      "enum": [
        "staged",
        "tracked",
        "daily_memory",
        "long_term_personalization"
      ]
    },
    "memory_type": {
      "type": "string",
      "enum": [
        "event",
        "task",
        "preference",
        "routine",
        "relationship",
        "profile",
        "correction"
      ]
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "dialogue",
        "onboarding",
        "user_correction",
        "system_writeback",
        "import"
      ]
    },
    "source_surface": {
      "type": "string",
      "enum": [
        "cmcp_policy",
        "cmcp_setup",
        "host_runtime_actions",
        "v2_runtime",
        "cmcp_guard"
      ]
    },
    "source_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "user_ownership": {
      "type": "string",
      "enum": [
        "explicit",
        "repeated",
        "derived"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "resolved",
        "cancelled",
        "superseded",
        "deleted",
        "expired"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "supersedes": {
      "type": [
        "string",
        "null"
      ]
    },
    "superseded_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "owner_surface": {
      "type": "string",
      "enum": [
        "cmcp_core",
        "cmcp_guard",
        "cmcp_policy",
        "cmcp_setup",
        "host_runtime_actions",
        "cmcp_product_page",
        "v2_runtime"
      ]
    },
    "invocation_area": {
      "type": "string",
      "enum": [
        "explicit_memory_save_action",
        "explicit_followup_action",
        "explicit_memory_correction_action",
        "cmcp_policy_manual_write",
        "cmcp_policy_manual_edit",
        "installer_disclosed_profile_capture",
        "onboarding_disclosed_profile_capture"
      ]
    },
    "field_key": {
      "type": "string"
    },
    "personalization_type": {
      "type": "string"
    },
    "stored_value": {
      "type": [
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "route_key": {
      "type": "string",
      "enum": [
        "manualMemoryWrite",
        "onboardingProfileCapture"
      ]
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "ordinary",
        "restricted",
        "forbidden"
      ]
    },
    "anchor_turns": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "text"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "text": {
            "type": "string",
            "maxLength": 1024
          }
        }
      }
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "continuity_value": {
      "type": "string",
      "maxLength": 4096
    },
    "resolution_condition": {
      "type": "string"
    },
    "latest_user_owned_clause": {
      "type": "string",
      "maxLength": 4096
    },
    "derived_from": {
      "type": "string"
    },
    "change_type": {
      "type": "string"
    },
    "stability_basis": {
      "type": "string"
    },
    "deleted_at": {
      "type": "string",
      "format": "date-time"
    },
    "deleted_by": {
      "type": "string",
      "enum": [
        "user",
        "system",
        "policy"
      ]
    },
    "deletion_reason": {
      "type": "string",
      "maxLength": 256
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "layer": {
            "const": "staged"
          }
        }
      },
      "then": {
        "required": [
          "anchor_turns",
          "expires_at"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "layer": {
            "const": "tracked"
          }
        }
      },
      "then": {
        "required": [
          "continuity_value",
          "resolution_condition",
          "latest_user_owned_clause"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "layer": {
            "const": "daily_memory"
          }
        }
      },
      "then": {
        "required": [
          "derived_from",
          "change_type"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "layer": {
            "const": "long_term_personalization"
          }
        }
      },
      "then": {
        "required": [
          "stability_basis"
        ]
      }
    }
  ]
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/cmcp-openclaw/schemas/cmcp-correction-action.schema.json",
  "title": "CmcpCorrectionAction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action",
    "target_scope",
    "redact_content"
  ],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "replace",
        "delete",
        "suppress",
        "resolve",
        "opt_out"
      ]
    },
    "target_memory_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "target_scope": {
      "type": "string",
      "enum": [
        "single_record",
        "memory_type",
        "category",
        "global"
      ]
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "apply_to_layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "session",
          "staged",
          "tracked",
          "daily_memory",
          "long_term_personalization"
        ]
      }
    },
    "replacement_memory_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "sourceSurface": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "cmcp_policy",
        "host_runtime_actions",
        null
      ]
    },
    "invocationArea": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "explicit_memory_correction_action",
        "cmcp_policy_manual_edit",
        null
      ]
    },
    "writeMode": {
      "type": "string",
      "enum": [
        "content_read_only_no_write",
        "explicit_write_enabled"
      ]
    },
    "preserve_tombstone": {
      "type": "boolean",
      "default": true
    },
    "redact_content": {
      "type": "boolean",
      "default": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "target_scope": {
            "const": "single_record"
          }
        }
      },
      "then": {
        "required": [
          "target_memory_id"
        ]
      }
    }
  ]
}
